+
+    private void showMockStatusTester() {
+        final TextView status = new TextView(this);
+        status.setPadding(48, 32, 48, 16);
+        status.setText("Reading Android location state...");
+        final AlertDialog dialog = new AlertDialog.Builder(this)
+                .setTitle("Mock location status")
+                .setView(status)
+                .setPositiveButton("Refresh", null)
+                .setNegativeButton("Close", null)
+                .create();
+
+        final LocationManager locationManager = (LocationManager) getSystemService(LOCATION_SERVICE);
+        dialog.setOnShowListener(ignored -> {
+            readAndroidMockStatus(status, locationManager);
+            dialog.getButton(AlertDialog.BUTTON_POSITIVE).setOnClickListener(v ->
+                    readAndroidMockStatus(status, locationManager));
+        });
+        dialog.show();
+    }
+
+    private void readAndroidMockStatus(TextView status, LocationManager locationManager) {
+        if (ActivityCompat.checkSelfPermission(this, Manifest.permission.ACCESS_FINE_LOCATION)
+                != PackageManager.PERMISSION_GRANTED) {
+            status.setText("Location permission is required to read Android location state.");
+            return;
+        }
+
+        try {
+            List<String> rawProviders = locationManager.getProviders(true);
+            if (rawProviders == null || rawProviders.isEmpty()) {
+                rawProviders = locationManager.getAllProviders();
+            }
+            LinkedHashSet<String> providers = new LinkedHashSet<>(rawProviders);
+
+            StringBuilder builder = new StringBuilder();
+            builder.append("GeoAvil service: ")
+                    .append(JoyStickManager.get().isStarted() ? "on" : "off")
+                    .append("\n");
+            builder.append("Source: Android LocationManager cache\n");
+            builder.append("Flag: Android Location.isMock / isFromMockProvider\n\n");
+
+            boolean foundLocation = false;
+            for (String provider : providers) {
+                Location location = locationManager.getLastKnownLocation(provider);
+                if (location == null) {
+                    builder.append(provider).append(": no last location\n");
+                    continue;
+                }
+
+                foundLocation = true;
+                builder.append(formatLocationForMockStatus(location)).append("\n\n");
+            }
+
+            if (!foundLocation) {
+                builder.append("No last known Android location yet.\n");
+                builder.append("Open Maps or start GeoAvil once, then refresh.");
+            } else if (!JoyStickManager.get().isStarted()) {
+                builder.append("\nNote: GeoAvil is off. Android can keep the last mock location cached after the service stops.");
+            }
+
+            status.setText(builder.toString().trim());
+        } catch (Exception e) {
+            status.setText("Unable to read Android location state: " + e.getMessage());
+        }
+    }
+
+    private String formatLocationForMockStatus(Location location) {
+        String provider = location.getProvider() == null ? "unknown" : location.getProvider();
+        return String.format(Locale.US,
+                "%s\nisMock = %s\nage = %s\nlat/lon = %.6f, %.6f\naccuracy = %.1f m",
+                provider,
+                isMockLocation(location) ? "true" : "false",
+                getLocationAge(location),
+                location.getLatitude(),
+                location.getLongitude(),
+                location.hasAccuracy() ? location.getAccuracy() : 0f);
+    }
+
+    private String getLocationAge(Location location) {
+        long elapsedNanos = location.getElapsedRealtimeNanos();
+        if (elapsedNanos <= 0) return "unknown";
+
+        long ageMillis = Math.max(0,
+                (SystemClock.elapsedRealtimeNanos() - elapsedNanos) / 1000000L);
+        if (ageMillis < 1000) return "live / under 1s";
+        if (ageMillis < 60000) return String.format(Locale.US, "%.1fs old", ageMillis / 1000f);
+        return String.format(Locale.US, "%.1fmin old", ageMillis / 60000f);
+    }
+
+    @SuppressWarnings("deprecation")
+    private boolean isMockLocation(Location location) {
+        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.S) {
+            return location.isMock();
+        }
+        return location.isFromMockProvider();
+    }
+
 
